    "Sync your transactions securely to your personal iCloud account. This seamlessly brings back your history on reinstall." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بمزامنة معاملاتك بشكل آمن مع حساب iCloud الشخصي الخاص بك. يؤدي هذا إلى إعادة السجل الخاص بك بسلاسة عند إعادة التثبيت."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincronice sus transacciones de forma segura con su cuenta personal de iCloud. Esto recupera sin problemas su historial al reinstalar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "トランザクションを個人の iCloud アカウントに安全に同期します。これにより、再インストール時に履歴がシームレスに戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "거래 내역을 개인 iCloud 계정에 안전하게 동기화하세요. 이렇게 하면 재설치 기록이 원활하게 복원됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将您的交易安全同步到您的个人 iCloud 帐户。这可以无缝地恢复您重新安装时的历史记录。"
          }
        }
      }
    },
