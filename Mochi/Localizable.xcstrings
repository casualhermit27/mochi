    "Thanks for being a lifetime member.\nNo expiry. No renewals. Ever." : {
      "comment" : "A description of the benefits of being a lifetime member.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شكرا لكونك عضوا مدى الحياة.\nلا انتهاء الصلاحية. لا التجديدات. أبدًا."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gracias por ser miembro vitalicio.\nSin caducidad. Sin renovaciones. Alguna vez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生涯会員になっていただきありがとうございます。\n有効期限はありません。更新はありません。これまで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "평생회원이 되어주셔서 감사합니다.\n만료가 없습니다. 갱신이 없습니다. 항상."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感谢您成为终身会员。\n没有期限。没有续订。曾经。"
          }
        }
      }
    },
    "Thanks for trying Mochi! Upgrade to\nMochi + to continue tracking." : {
      "comment" : "A description of the benefits of upgrading to Mochi +.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
