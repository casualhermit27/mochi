    "Long press any number on the keypad to\ninstantly add a preset transaction." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط لفترة طويلة على أي رقم على لوحة المفاتيح للقيام بذلك\nإضافة معاملة محددة مسبقًا على الفور."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenga presionado cualquier número en el teclado para\nagregue instantáneamente una transacción preestablecida."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キーパッドの任意の数字を長押しすると、\nプリセットされたトランザクションを即座に追加します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "키패드의 아무 숫자나 길게 누르면\n미리 설정된 거래를 즉시 추가하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长按键盘上的任意数字即可\n立即添加预设交易。"
          }
        }
      }
    },
